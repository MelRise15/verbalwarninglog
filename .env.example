# ─────────────────────────────────────────────────────────────
# RISE Armament — Verbal Warning Log
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# Azure AD App Registration (see README for setup steps)
AZURE_CLIENT_ID=your-application-client-id-here
AZURE_TENANT_ID=your-directory-tenant-id-here
AZURE_CLIENT_SECRET=your-client-secret-value-here

# Where Microsoft redirects users after login.
# Must exactly match a Redirect URI registered in Azure AD.
# Local dev:   http://localhost:3000/auth/callback
# Production:  https://yourapp.yourdomain.com/auth/callback
REDIRECT_URI=http://localhost:3000/auth/callback

# Full URL of the app (used for post-logout redirect)
APP_URL=http://localhost:3000

# Random string — change this to something long and secret
SESSION_SECRET=replace-with-a-long-random-string-32-chars-min

# Path to the SQLite database file (default: ./warnings.db in app directory)
# DB_PATH=./warnings.db

# Set to "production" in deployed environments
# NODE_ENV=production

# Port (default: 3000)
# PORT=3000

# ─────────────────────────────────────────────────────────────
# RISE Armament — Verbal Warning Log
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# Admin access — comma-separated Microsoft 365 emails that can see ALL warnings
# Example: ADMIN_EMAILS=mmcfarland@risearmament.com,jdoe@risearmament.com
ADMIN_EMAILS=

# Supabase — get these from your Supabase project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase PostgreSQL connection string — for session storage
# Get from: Supabase → Settings → Database → Connection string → URI (Session mode, port 5432)
DATABASE_URL=postgresql://postgres.xxxx:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Anthropic API key — used to auto-punctuate dictated text
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Azure AD App Registration (see README for setup steps)
AZURE_CLIENT_ID=your-application-client-id-here
AZURE_TENANT_ID=your-directory-tenant-id-here
AZURE_CLIENT_SECRET=your-client-secret-value-here

# Where Microsoft redirects users after login.
# Must exactly match a Redirect URI registered in Azure AD.
# Local dev:   http://localhost:3000/auth/callback
# Production:  https://yourapp.yourdomain.com/auth/callback
REDIRECT_URI=http://localhost:3000/auth/callback

# Full URL of the app (used for post-logout redirect)
APP_URL=http://localhost:3000

# Random string — change this to something long and secret in production
SESSION_SECRET=replace-with-a-long-random-string-32-chars-min

# Set to "production" in deployed environments
# NODE_ENV=production

# Port (default: 3000)
# PORT=3000
